# ---------- ingest intermediates (regenerable from reel.webm) ----------
# Whisper extracts and large frame stacks are produced fresh by the ingest
# pipeline. Keeping them out of the repo holds the public site lean.
sources/captures/*/reel-audio.wav
sources/captures/*/reel-audio.mp3
sources/captures/*/reel-audio.srt
sources/captures/*/reel-audio.vtt
sources/captures/*/reel-audio.tsv
sources/captures/*/reel-audio.json
sources/captures/*/_meta_raw.json
sources/captures/*/frames/f0[0-9][2-9].png
sources/captures/*/frames/f01[0-9].png
sources/captures/*/frames/f0[2-9][0-9].png
sources/captures/*/frames/f[1-9][0-9][0-9].png
